{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Create Package",
            "type": "debugpy",
            "request": "launch",
            "module": "hatch",
            "console": "integratedTerminal",
            "args": ["build", "--target", "kicad-package"]
        },
        {
            "name": "Run Plugin",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/src",
            "module": "run_simulator",
            "console": "integratedTerminal",
            "env": {
                "KICAD_API_SOCKET": "ipc:///tmp/kicad/api.sock",
                "KICAD_API_TOKEN": "2d07a6de-55f1-4ac7-acc0-bb49c6f05928"
            },
            "args": ["--log-level=DEBUG"],
            "justMyCode": false
        },
        {
            "name": "Run App",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/src",
            "module": "run_simulator",
            "console": "integratedTerminal",
            "args": ["--log-level=DEBUG"],
            "justMyCode": false
        }
    ]
}